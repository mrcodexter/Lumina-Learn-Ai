{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "StudyNote": {
      "title": "Study Note",
      "description": "AI-generated study notes for a specific topic.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content of the note" },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "content"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "AI-generated quiz for a topic.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "questions"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/notes/{noteId}": {
      "schema": "StudyNote",
      "description": "Collection of study notes"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of quizzes"
    }
  }
}
